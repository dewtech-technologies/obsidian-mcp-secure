# Obsidian MCP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# API Key gerada pelo plugin Local REST API do Obsidian
# Settings → Local REST API → API Key
OBSIDIAN_API_KEY=cole_sua_api_key_aqui

# Host e porta do Local REST API (padrão: 127.0.0.1:27123)
OBSIDIAN_HOST=http://127.0.0.1
OBSIDIAN_PORT=27123

# Pasta onde os logs de auditoria serão salvos
LOG_DIR=./logs
